  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.27.0",
    "zmp-sdk": "2.51.1",
    "zmp-ui": "1.11.14",
    "zustand": "5.0.1",
    "@tanstack/react-query": "5.59.20",
    "react-hook-form": "7.53.2",
    "zod": "3.23.8",
    "axios": "1.7.7",
    "date-fns": "4.1.0",
    "lucide-react": "0.460.0",
    "tailwindcss": "3.4.14",
    "tailwind-merge": "2.5.4",
    "clsx": "2.1.1"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@types/node": "22.9.0",
    "typescript": "5.6.3",
    "vite": "5.4.10",
    "@vitejs/plugin-react": "4.3.3",
    "zmp-cli": "3.15.15",
    "vitest": "2.1.5",
    "@testing-library/react": "16.0.1",
    "eslint": "8.57.1",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.8",
    "postcss": "8.4.49",
    "autoprefixer": "10.4.20"
